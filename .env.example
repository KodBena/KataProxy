# ============================================================================
# KataProxy environment configuration
# ============================================================================
#
# Copy this file to `.env` in the project root and edit the values you need.
# Anything not set here falls back to the hard defaults in sproxy_config.py.
# Variables already set in your shell (e.g. via export) take precedence over
# anything in this file.
#
# ----------------------------------------------------------------------------
#                       MINIMAL LEAF CONFIGURATION
#         (the only section most users will ever need to touch)
# ----------------------------------------------------------------------------
#
# A LEAF runs a local KataGo subprocess and serves analysis to clients.
# To start one, you need three things: the katago executable, an analysis
# config file, and a neural network model.
#

# Path to the katago executable.
# If katago is on your PATH, leave this as `katago`.
# Otherwise: an absolute path, e.g. /usr/local/bin/katago or
# C:\Users\you\katago\katago.exe
KATAGO_PATH=katago

# Path to the analysis config (.cfg file shipped with KataGo).
KATAGO_CFG=analysis.cfg

# Path to the neural network model file (.bin.gz or .txt.gz).
# Required for LEAF role. RELAY/ECHO do not need this.
KATAGO_MODEL=

# Seconds the LEAF startup gate waits for KataGo to acknowledge a probe
# query before declaring startup failed. Cold model loads can be slow on
# spinning disks or weak GPUs; the default is generous. If KataGo does
# not respond in this window, the proxy refuses to start and prints the
# captured KataGo stderr so the operator can see what went wrong.
# KATAGO_STARTUP_TIMEOUT_S=60

# TCP port the proxy listens on. Default 41949.
PROXY_PORT=41949


# ============================================================================
#                       EVERYTHING BELOW IS OPTIONAL
# ============================================================================
#
# The defaults are sensible for local development. Touch these only if you
# are running RELAY/ECHO roles, exposing the proxy beyond localhost, or
# tuning load balancing.


# ----------------------------------------------------------------------------
# Network binding
# ----------------------------------------------------------------------------

# Address to bind. Default 127.0.0.1 (loopback only).
# Set to 0.0.0.0 to accept connections from other machines.
# CAUTION: this proxy has no authentication. If you need to expose it to a
# network you do not fully trust, put it behind an SSH tunnel, WireGuard,
# or an authenticating reverse proxy (e.g. nginx with mTLS).
PROXY_HOST=127.0.0.1


# ----------------------------------------------------------------------------
# Role selection
# ----------------------------------------------------------------------------
#
# LEAF      — spawn a local KataGo subprocess (the default; described above)
# RELAY     — forward queries to one or more upstream LEAF/RELAY nodes,
#             with consistent-hash load balancing across them
# ECHO      — return synthetic responses immediately; for testing
# REDIRECT  — tell connecting clients to reconnect elsewhere
#             (no analysis performed; advertises UPSTREAM_URLS to the client)

PROXY_ROLE=LEAF


# ----------------------------------------------------------------------------
# RELAY / REDIRECT configuration
# ----------------------------------------------------------------------------

# Comma-separated list of upstream WebSocket URLs.
# Required for RELAY and REDIRECT roles; ignored otherwise.
# Example: UPSTREAM_URLS=ws://leaf-a.lan:41949,ws://leaf-b.lan:41949
UPSTREAM_URLS=

# RELAY only: maximum in-flight queries per upstream before the router
# starts walking the hash ring to a less-loaded peer. Default 10.
# Increase for upstreams with more GPU capacity; decrease for tighter
# tail-latency guarantees.
RELAY_MAX_LOAD=10

# RELAY only: virtual nodes per upstream in the consistent-hash ring.
# Default 150 follows the conventional 100-200 range. Higher values give
# smoother distribution at the cost of more memory and slower lookups.
# You almost certainly do not need to change this.
HASH_RING_REPLICAS=150


# ----------------------------------------------------------------------------
# Hub replay-cache bound (v1.0.4)
# ----------------------------------------------------------------------------
#
# Maximum number of analysis-level replay-cache entries the hub keeps before
# evicting the least-recently-used. The cache is populated when a client
# submits a query with {"cache": true} and replayed when {"lookup_cache":
# true} matches the same query later.
#
# Default 1024 is conservative; operators with large active query corpora
# may want substantially higher. Set to 0 (or any non-positive integer) to
# disable the bound entirely — the cache then grows without limit.
# CAUTION: unbounded growth is a one-connection memory-amplification
# surface (any client can churn unique cache=true queries to OOM the
# process); set 0 only when you trust the wire or have other defenses.
# PROXY_HUB_CACHE_MAX=1024


# ----------------------------------------------------------------------------
# JSON structural depth bound (v1.0.4)
# ----------------------------------------------------------------------------
#
# Maximum nesting depth accepted on inbound JSON. Payloads exceeding this
# depth are refused before json.loads runs, so a depth-bombed message can't
# trip Python's recursion limit and tear down the receive loop.
#
# Default 64; legitimate KataGo JSON is depth ≤ 5 in practice. Set to 0 (or
# any non-positive integer) to disable the check entirely.
# PROXY_JSON_MAX_DEPTH=64


# ----------------------------------------------------------------------------
# Connection-level resource caps (v1.0.4)
# ----------------------------------------------------------------------------

# Maximum WebSocket message size accepted from a client, in bytes. This
# applies to inbound client queries only — KataGo response sizes (which
# run ~48 KB per turn with the policy head and ownership map enabled)
# flow outbound and are unaffected. Realistic inbound queries are well
# under 100 KB even with rich analysis_config payloads; the pre-v1.0.4
# default of 64 MB was the most exploitable value in the codebase, and
# 4 MB gives wide headroom for any legitimate inbound shape.
# PROXY_MAX_MESSAGE_SIZE=4194304

# Maximum number of concurrent client WebSocket sessions. New connections
# above the cap close with WebSocket code 1013 (try again later). Set to 0
# (or any non-positive integer) to disable the cap entirely. 256 covers
# small-to-medium go-school deployments.
# PROXY_MAX_SESSIONS=256

# Per-IP query rate limit, in queries per minute. When set, exceeding the
# rate causes the offending message to be dropped (with a WARNING log);
# the connection itself stays open. Default 0 (off) — appropriate for
# deployments behind a reverse proxy where the proxy sees the reverse-
# proxy IP for every user. Operators with direct internet exposure may
# want to set this to e.g. 600 (10 q/sec sustained).
# PROXY_RATELIMIT_PER_IP=0


# ----------------------------------------------------------------------------
# Adaptive middleware (v1.0.5)
# ----------------------------------------------------------------------------
#
# Per-session bound on the number of in-flight queries the
# AdaptiveReevaluateMiddleware tracks. On overflow, the oldest in-flight
# entry is dropped (its buffered finals lost; subsequent responses for that
# orig_id flow through unchanged). 128 is generous; typical sessions have
# well under 10 in-flight queries.  Set to 0 to disable the bound entirely.
# PROXY_ADAPTIVE_MAX_INFLIGHT=128
